    "steps": [
      { "bg": "black" },
      { "say": "", "text": "――笑いで、てっぺんを獲る。そう言って大阪を飛び出したのが、十年前。" },

      { "bg": "river_dusk" },
      { "chara": "hero", "face": "base", "pos": "C" },
      { "say": "", "text": "あれから七年。俺はまだ、何者にもなれていない。" },

      { "se": "blip" },
      { "say": "", "text": "……美咲からの、メッセージ。" },

      { "say": "美咲(メッセージ)", "text": "「久しぶり。元気にしてる？ こっち帰ってくる予定、あったりする？」" },

      { "chara": "hero", "face": "suberi", "pos": "C" },
      { "say": "", "text": "幼なじみの、美咲。俺が東京に出てから、ずっと大阪で待ってくれている。……もう、七年も。" },
      { "say": "", "text": "返信を打とうとして、指が止まる。「売れたら帰る」なんて、何度言っただろう。その「いつか」を、俺はずっと先延ばしにしてきた。" },

      { "bg": "backstage" },
      { "hide": "all" },
      { "chara": "partner", "face": "base", "pos": "R" },
      { "say": "矢田", "text": "「おーい、なに辛気くさい顔してるでげすか。次の出番、もうすぐでげすよ」" },
      { "chara": "hero", "face": "base", "pos": "L" },
      { "say": "", "text": "相方の、矢田。養成所からの同期で、もう十年の付き合いになる。ネタは俺が書く。こいつは……まあ、ムードメーカーや。" },

      { "chara": "partner", "face": "warai", "pos": "R" },
      { "say": "矢田", "text": "「彼女から『帰ってこい』て？ オイラは『や〜だ』。……なんちゃって。やだ、だけにね、ゲスゲス!」" },
      { "se": "blip" },
      { "say": "", "text": "……こいつのギャグは、今日も一ミリも刺さらない。" },

      { "chara": "partner", "face": "base", "pos": "R" },
      { "say": "矢田", "text": "「……ねえ。{player}くん、ほんとにこのままでいいでげすか」" },
      { "say": "矢田", "text": "「オイラたちもう、若手とは言えない歳でげすよ。美咲ちゃんのことも、ずっと待たせたままでげすし…」" },
      { "say": "", "text": "ふざけてばかりの矢田が、珍しく真顔だった。……分かってる。誰よりも、俺が分かってる。" },

      { "bg": "sepia_flashback" },
      { "hide": "all" },
      { "chara": "hero", "face": "base", "pos": "L" },
      { "chara": "misaki", "pos": "R" },
      { "say": "", "text": "十年前。大阪を発つ、あの日。" },
      { "say": "美咲(回想)", "text": "「……行っちゃうんやね。」" },
      { "say": "{player}(回想)", "text": "「ああ。笑いで、てっぺん獲ってくる。」" },
      { "say": "", "text": "あの時の俺は、根拠もないのに自信だけはあった。美咲は何も言わずに、ただ笑って見送ってくれた。その笑顔が、ずっと胸に刺さったままだ。" },

      { "bg": "backstage" },
      { "hide": "all" },
      { "chara": "hero", "face": "tsukkomi", "pos": "C" },
      { "say": "", "text": "もう、先延ばしにはできない。ここらで、ケジメをつけなあかん。" },

      { "choice": [
        { "label": "「あと三年で、てっぺんを獲る」", "goto": "KETSUI" },
        { "label": "「十年目のМ-1で、結果を出す」", "goto": "KETSUI" },
        { "label": "「ダメなら……大阪に帰る」", "goto": "KETSUI" }
      ] },
      { "label": "KETSUI" },

      { "say": "", "text": "芸歴十年目――来年の、Ｍ-1グランプリ。そこで優勝できなければ、俺は芸人を辞める。大阪に帰って、美咲に……ちゃんと、向き合う。" },

      { "chara": "hero", "face": "tsukkomi", "pos": "C" },
      { "say": "", "text": "残された時間は、三年。……いや、三年も、ある。" },

      { "say": "{player}(メッセージ)", "text": "「美咲。あと三年だけ、待っててくれへんか。絶対に、笑い者やない――\"笑わせる側\"の、てっぺん獲ったる。」" },
      { "se": "blip" },
      { "say": "美咲(メッセージ)", "text": "「……うん。待ってる。あんたの漫才、私は世界一やと思てるから。」" },

      { "bg": "black" },
      { "hide": "all" },
      { "say": "", "text": "――こうして、俺の\"崖っぷちの三年\"が、幕を開けた。" }
    ]
  }
