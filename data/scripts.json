      { "se": "blip" },
      { "eff": { "idea": 5 } },
      { "say": "{player}", "text": "よし、発想力+5や！", "face": "warai" },
      { "jump": "END" },
      { "label": "B" },
      { "se": "blip" },
      { "eff": { "trust": 3 } },
      { "say": "矢田", "text": "おっ、信頼度+3やん。ええ相方や。", "face": "warai" },
