{
  "TEST-01": {
    "title": "疎通テスト",
    "steps": [
      { "bg": "street_night" },
      { "chara": "hero", "face": "base", "pos": "L" },
      { "chara": "partner", "face": "base", "pos": "R" },
      { "say": "{player}", "text": "よっしゃ、シナリオエンジンの疎通テストや。", "face": "base" },
      { "say": "矢田", "text": "え、ワイもう出てるん？段取り早すぎひん？", "face": "warai" },
      { "say": "{player}", "text": "そういうもんや。ほな、選んでや。", "face": "tsukkomi" },
      { "choice": [
